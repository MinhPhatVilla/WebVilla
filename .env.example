# 🏠 MINH PHÁT VILLA - ENVIRONMENT VARIABLES TEMPLATE
# Sao chép file này thành .env.local và điền giá trị thật vào
# cp .env.example .env.local
#
# ⚠️ KHÔNG BAO GIỜ commit file .env.local lên Git!

# ── Sanity CMS ──────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=your-sanity-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
# SANITY_API_TOKEN=your-sanity-write-token (optional)

# ── Supabase Database ────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# 🔐 Service Role Key (CHỈ DÙNG SERVER-SIDE — KHÔNG prefix NEXT_PUBLIC_!)
# Lấy từ: Supabase Dashboard > Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Telegram Notifications ───────────────────────────────
# Lấy từ: @BotFather trên Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ── Admin Dashboard ──────────────────────────────────────
# Đăng nhập admin bằng email/password đã đăng ký trên website
# User phải có role='admin' trong bảng public.users
# (Không cần biến env nào thêm — dùng Supabase Auth)
